#!/usr/bin/env python3
from MangDang.mini_pupper.ESP32Interface import ESP32Interface
from MangDang.mini_pupper.display import Display, BehaviorState
import time
import subprocess
from pathlib import Path


def find_bsp_script():
    candidates = sorted(Path('/home').glob('*/mini_pupper_bsp/FuelGauge/play-low-power-sound.sh'))
    candidates += sorted(Path('/home').glob('*/mini_pupper_2_bsp/FuelGauge/play-low-power-sound.sh'))
    if candidates:
        return str(candidates[0])
    fallback = Path('/root/mini_pupper_bsp/FuelGauge/play-low-power-sound.sh')
    if fallback.exists():
        return str(fallback)
    fallback = Path('/root/mini_pupper_2_bsp/FuelGauge/play-low-power-sound.sh')
    if fallback.exists():
        return str(fallback)
    return None

#Power monitor
def main():
    esp32 = ESP32Interface()
    low_power_script = find_bsp_script()
    while True:
        power_status=esp32.get_power_status()
        if power_status == None:
            continue
        current_voltage=power_status['volt']
        # Servos will be disabled by ESP32 when power is low
        # The threshold value: 
        #      4.2 is for Raspberry Pi 4B USB typeC adapter.
        #      4.5 is for Raspberry Pi 5 USB typeC adapter.
        #      6.2 is for our battery adapter.
        if current_voltage <= 4.20:
            if low_power_script:
                subprocess.run([low_power_script], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            disp = Display()
            disp.show_state(BehaviorState.LOWBATTERY)
        time.sleep(8)

if __name__ == '__main__':
    main()
